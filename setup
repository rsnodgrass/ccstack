#!/usr/bin/env bash
set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
TARGET="$HOME/.claude/commands"
mkdir -p "$TARGET"

count=0
for skill in "$SCRIPT_DIR"/rs-*.md; do
  [ -f "$skill" ] || continue
  name="$(basename "$skill")"
  ln -sf "$skill" "$TARGET/$name"
  echo "  installed /$(basename "$name" .md)"
  count=$((count + 1))
done

echo ""
echo "Done. $count rs-dev skills installed to $TARGET"
echo "Type /rs- in Claude Code to see them all."
